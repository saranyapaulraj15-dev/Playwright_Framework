{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@utils/*": ["src/utils/*"],
      "@tests/*": ["src/tests/*"]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "playwright.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "playwright-report",
    "allure-results",
    "allure-report",
    "test-results"
  ]
}
